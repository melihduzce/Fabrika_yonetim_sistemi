  "muhasebe": {
    "aciklama": "Muhasebe sayfası: Giderler (sabit + değişken) ve Gelirler (müşteri satışları + tahmini). Net kar = ortalama gelir - toplam gider. Frontend aylık satışları sipariş verisinden tarih ile gruplar. Gider Düzenle sayfası tek listede id, kalem, tutar, tip ile çalışır.",
    "endpoints": {
      "giderler_sabit": { "method": "GET", "path": "/api/muhasebe/giderler/sabit", "aciklama": "Aylık sabit gider kalemleri ve tutarları" },
      "giderler_degisken": { "method": "GET", "path": "/api/muhasebe/giderler/degisken", "aciklama": "Aylık değişken gider kalemleri (üretim maliyetleri)" },
      "giderler_tek_liste": {
        "liste": { "method": "GET", "path": "/api/muhasebe/giderler", "aciklama": "Tüm giderler tek listede (id, kalem, tutar, tip)" },
        "ekle": { "method": "POST", "path": "/api/muhasebe/giderler" },
        "guncelle": { "method": "PUT", "path": "/api/muhasebe/giderler/:id" },
        "sil": { "method": "DELETE", "path": "/api/muhasebe/giderler/:id" }
      },
      "gelirler_satislar": { "method": "GET", "path": "/api/muhasebe/gelirler/satislar", "aciklama": "Müşteri satışları (siparişlerden türetilebilir veya ayrı kayıt); aylık/müşteri bazlı" },
      "tahmini": { "method": "GET", "path": "/api/muhasebe/tahmini", "aciklama": "Beklenen üretim ve tahmini gelir" }
    },
    "gider_tek_liste_schema": {
      "id": "number (benzersiz)",
      "kalem": "string",
      "tutar": "number (TRY/ay)",
      "tip": "string: 'sabit' | 'degisken'"
    },
    "gider_ekle_guncelle_body": {
      "kalem": "string (zorunlu)",
      "tutar": "number (zorunlu, >= 0)",
      "tip": "string (zorunlu): 'sabit' | 'degisken'"
    },
    "sabit_gider_schema": {
      "kalem": "string (Elektrik, İşçilik, SGK, Yol, Yemek, Bakım, Nakliye, Kira)",
      "tutar": "number (TRY/ay)"
    },
    "degisken_gider_schema": {
      "kalem": "string (Hammadde alımı, Hurda kaybı)",
      "tutar": "number (TRY/ay)"
    },
    "ornek_sabit_giderler": [
