  "auth": {
    "login": {
      "request": {
        "email": "string (zorunlu)",
        "password": "string (zorunlu)",
        "rememberMe": "boolean (opsiyonel)"
      },
      "response_ornek": {
        "token": "string",
        "user": {
          "id": "string",
          "email": "string",
          "displayName": "string"
        }
      }
    },
    "register": {
      "request": {
        "email": "string",
        "password": "string",
        "displayName": "string (opsiyonel)"
      }
    }
  },
