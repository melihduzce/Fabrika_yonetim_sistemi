  "meta": {
    "proje": "Fabrika Yönetim Sistemi (Fabrika YS)",
    "versiyon": "2.1",
    "aciklama": "Frontend ile birebir uyumlu API spesifikasyonu. Backend ekibinin endpoint, şema ve örnek verileri tek dosyadan takip etmesi için hazırlanmıştır.",
    "son_guncelleme": "2025-02-26",
    "degisiklik_log": [
      "v2.1: Müşteri tam CRUD (Müşteriler / Müşteri Ekle / Müşteri Bilgi) şeması ve endpoint'leri eklendi.",
      "v2.1: Makine şemasına idKod alanı ve sil endpoint'i eklendi; örnek liste 6 makineye çıkarıldı.",
      "v2.1: Muhasebe giderler için tek liste alternatifi (id, kalem, tutar, tip) ve CRUD endpoint'leri eklendi.",
      "v2.1: Tarih alanları için ISO 8601 (YYYY-MM-DD) kabul notu eklendi.",
      "v2.1: referans_degerler.musteri_tip eklendi."
    ],
    "tarih_formatı": "DD.MM.YYYY (örn: 25.02.2025). ISO 8601 (YYYY-MM-DD) da kabul edilir; frontend her iki formatı destekler.",
    "para_birimi": "TRY (₺), ondalık ayırıcı virgül (tr-TR)",
    "varsayilan_base_url": "https://api.example.com/v1"
  },

  "genel_notlar": {
    "kimlik_dogrulama": "Login sonrası dönen token, isteklerde Header: Authorization: Bearer <token> ile gönderilir.",
    "hata_cevabi": "4xx/5xx durumlarında { \"error\": \"string\", \"code\": \"string (opsiyonel)\" } önerilir.",
    "sayfalama": "Liste endpoint'lerinde ?page=1&limit=20 gibi parametreler opsiyonel eklenebilir."
  },

  "auth": {
    "login": {
      "method": "POST",
      "endpoint": "/auth/login",
      "request_body": {
        "email": "string (zorunlu)",
        "password": "string (zorunlu)",
        "rememberMe": "boolean (opsiyonel, varsayılan false)"
      },
      "response_200_ornek": {
        "token": "string (JWT veya session token)",
        "user": {
          "id": "string",
          "email": "string",
          "displayName": "string"
        }
      }
    },
    "register": {
      "method": "POST",
      "endpoint": "/auth/register",
      "request_body": {
        "email": "string (zorunlu)",
        "password": "string (zorunlu)",
        "displayName": "string (opsiyonel)"
      },
      "response_200_ornek": {
        "token": "string",
        "user": { "id": "string", "email": "string", "displayName": "string" }
      }
    }
  },

